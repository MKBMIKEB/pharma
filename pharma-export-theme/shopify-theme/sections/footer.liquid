<footer class="footer">
  <div class="container-narrow section-padding">
    <div class="footer__grid">
      {%- comment -%} Brand Column {%- endcomment -%}
      <div>
        <div class="flex items-center gap-2 mb-4">
          {%- if section.settings.logo -%}
            <img src="{{ section.settings.logo | image_url: height: 32 }}" alt="{{ shop.name }}" height="32">
          {%- else -%}
            <div class="header__logo-icon" style="background: rgba(250,249,247,0.2);">
              <span>V+</span>
            </div>
            <span class="header__logo-text" style="color: var(--color-primary-foreground);">{{ shop.name }}</span>
          {%- endif -%}
        </div>
        <p class="footer__brand-desc">{{ section.settings.brand_description }}</p>
      </div>

      {%- comment -%} Menu Columns {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          <h4 class="footer__heading">{{ block.settings.heading }}</h4>
          {%- if block.settings.menu != blank -%}
            <div class="footer__links">
              {%- for link in linklists[block.settings.menu].links -%}
                <a href="{{ link.url }}">{{ link.title }}</a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} Disclaimer {%- endcomment -%}
    <div class="footer__disclaimer">
      <p class="footer__disclaimer-text">
        <strong>{{ 'footer.disclaimer_label' | t }}</strong> {{ settings.legal_disclaimer }}
      </p>
      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'footer.rights' | t }}
      </p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Pie de página",
  "class": "footer-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo del footer"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Descripción de la marca",
      "default": "Suplementos de salud de calidad premium. Tu bienestar, nuestra prioridad."
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Columna de menú",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título de columna",
          "default": "Enlaces"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menú"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Pie de página",
      "blocks": [
        { "type": "menu", "settings": { "heading": "Tienda" } },
        { "type": "menu", "settings": { "heading": "Información" } },
        { "type": "menu", "settings": { "heading": "Legal" } }
      ]
    }
  ]
}
{% endschema %}
