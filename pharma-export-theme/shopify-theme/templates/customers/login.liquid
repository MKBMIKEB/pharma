<div class="customer-page">
  <div class="customer-page__icon">
    {% render 'icon', icon: 'users', size: 32 %}
  </div>
  <h1>{{ 'customer.login_title' | t }}</h1>
  <p class="customer-page__subtitle">{{ 'customer.login_subtitle' | t }}</p>

  <div id="LoginFormWrap">
    {% form 'customer_login' %}
      {%- if form.errors -%}
        <div class="alert alert--warning mb-4">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <div class="form-group">
        <label for="customer-email">{{ 'customer.email' | t }}</label>
        <input type="email" id="customer-email" name="customer[email]" class="input" required autocomplete="email" placeholder="{{ 'customer.email_placeholder' | t }}">
      </div>

      <div class="form-group">
        <label for="customer-password">{{ 'customer.password' | t }}</label>
        <div class="input-password-wrap">
          <input type="password" id="customer-password" name="customer[password]" class="input" required autocomplete="current-password">
          <button type="button" class="input-password-toggle" data-toggle-password="customer-password" aria-label="{{ 'customer.show_password' | t }}">
            {% render 'icon', icon: 'eye', size: 18 %}
          </button>
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-lg w-full mb-4">
        {{ 'customer.login' | t }}
      </button>

      <div class="customer-page__links">
        <a href="/account/register" class="text-sm text-primary font-medium">{{ 'customer.register' | t }}</a>
        <a href="#recover" class="text-sm text-muted" id="RecoverLink">{{ 'customer.forgot_password' | t }}</a>
      </div>
    {% endform %}
  </div>

  <div id="RecoverForm" class="customer-recover" style="display:none;">
    <h2 class="font-display text-xl font-bold text-center mb-2">{{ 'customer.reset_password' | t }}</h2>
    <p class="text-sm text-muted text-center mb-4">{{ 'customer.reset_instructions' | t }}</p>
    {% form 'recover_customer_password' %}
      <div class="form-group">
        <label for="recover-email">{{ 'customer.email' | t }}</label>
        <input type="email" id="recover-email" name="email" class="input" required placeholder="{{ 'customer.email_placeholder' | t }}">
      </div>
      <button type="submit" class="btn btn-primary btn-lg w-full mb-4">{{ 'customer.send_reset' | t }}</button>
      <button type="button" class="btn btn-ghost w-full text-sm" id="RecoverCancel">{{ 'customer.back_to_login' | t }}</button>
    {% endform %}
  </div>
</div>

<script>
(function() {
  var loginWrap = document.getElementById('LoginFormWrap');
  var recoverForm = document.getElementById('RecoverForm');
  var recoverLink = document.getElementById('RecoverLink');
  var recoverCancel = document.getElementById('RecoverCancel');

  if (recoverLink) {
    recoverLink.addEventListener('click', function(e) {
      e.preventDefault();
      loginWrap.style.display = 'none';
      recoverForm.style.display = 'block';
    });
  }
  if (recoverCancel) {
    recoverCancel.addEventListener('click', function() {
      recoverForm.style.display = 'none';
      loginWrap.style.display = 'block';
    });
  }

  if (window.location.hash === '#recover') {
    loginWrap.style.display = 'none';
    recoverForm.style.display = 'block';
  }
})();
</script>
