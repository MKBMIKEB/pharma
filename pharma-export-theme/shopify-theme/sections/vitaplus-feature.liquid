<section class="vitaplus-feature section-padding">
  <div class="container-narrow vitaplus-feature__inner">
    <div class="vitaplus-feature__visual" data-reveal>
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 700 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
          width="700"
          height="{{ 700 | divided_by: section.settings.image.aspect_ratio }}"
          loading="lazy"
        >
      {%- else -%}
        <div class="vitaplus-feature__badge">
          <div class="header__logo-icon green-gradient">
            <span>V+</span>
          </div>
          <span>Vita Plus</span>
        </div>
      {%- endif -%}
    </div>

    <div class="vitaplus-feature__text" data-reveal style="transition-delay: 0.1s">
      {%- if section.settings.eyebrow != blank -%}
        <span class="hero__tag">
          {% render 'icon', icon: 'heart', size: 14 %}
          {{ section.settings.eyebrow }}
        </span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="vitaplus-feature__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <a href="{{ section.settings.button_url | default: '/pages/vitaplus' }}" class="btn btn-primary btn-lg">
          {{ section.settings.button_text }}
          {% render 'icon', icon: 'arrow-right', size: 18 %}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Destacado Vita Plus",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta pequeña",
      "default": "Nuestra línea de bienestar"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Bienestar que acompaña tu ritmo"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción",
      "default": "Conoce Vita Plus, nuestra selección de productos pensados para complementar tus hábitos y tu bienestar diario."
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "URL del botón",
      "info": "Por defecto va a /pages/vitaplus"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Ir a Vita Plus"
    }
  ],
  "presets": [
    {
      "name": "Destacado Vita Plus"
    }
  ]
}
{% endschema %}
