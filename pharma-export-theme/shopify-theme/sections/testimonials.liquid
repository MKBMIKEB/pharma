<section class="section-padding">
  <div class="container-narrow">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="section-subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {%- for block in section.blocks -%}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="mb-3">
            {% render 'star-rating', rating: block.settings.rating, count: 0 %}
          </div>
          <p class="testimonial-card__text">"{{ block.settings.text }}"</p>
          <p class="testimonial-card__author">{{ block.settings.author }}</p>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.disclaimer != blank -%}
      <p class="text-xs text-muted text-center mt-8">{{ section.settings.disclaimer }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Testimonios",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Lo que dicen nuestros clientes"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Experiencias reales de personas que confían en VitalPlus"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Texto disclaimer",
      "default": "Resultados individuales pueden variar. Estos testimonios no constituyen consejo médico."
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonio",
      "settings": [
        {
          "type": "text",
          "id": "author",
          "label": "Nombre del cliente",
          "default": "Cliente"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto del testimonio",
          "default": "He notado un cambio positivo en mi bienestar general desde que empecé a tomar estos suplementos."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Calificación (estrellas)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Testimonios",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "author": "Carlos M.",
            "text": "He notado un cambio positivo en mi bienestar general. La calidad de VitalPlus es excepcional.",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "author": "Andrea L.",
            "text": "El Multivitamínico Diario me ha dado más energía. Lo recomiendo totalmente.",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "author": "Jorge P.",
            "text": "El Magnesio + Zinc mejoró mi calidad de sueño notablemente. Excelente producto.",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
