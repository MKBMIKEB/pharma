<section class="hero{% if section.settings.style == 'neon' %} hero--neon{% endif %}" data-hero>
  {%- assign slide_blocks = section.blocks | where: "type", "slide" -%}

  {%- if slide_blocks.size > 0 -%}
    <div class="hero__carousel" data-hero-carousel>
      {%- for block in slide_blocks -%}
        <div class="hero__slide {% if forloop.first %}is-active{% endif %}" {{ block.shopify_attributes }}>
          <img
            src="{{ block.settings.image | image_url: width: 1920 }}"
            alt="{{ block.settings.alt | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            {% if forloop.first %}fetchpriority="high"{% endif %}
          >
        </div>
      {%- endfor -%}
    </div>
    <div class="hero__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
    {%- if slide_blocks.size > 1 -%}
      <button class="hero__carousel-arrow hero__carousel-arrow--prev" data-carousel-prev aria-label="Slide anterior">
        {% render 'icon', icon: 'arrow-left', size: 20 %}
      </button>
      <button class="hero__carousel-arrow hero__carousel-arrow--next" data-carousel-next aria-label="Siguiente slide">
        {% render 'icon', icon: 'arrow-right', size: 20 %}
      </button>
      <div class="hero__carousel-dots">
        {%- for block in slide_blocks -%}
          <button class="hero__carousel-dot {% if forloop.first %}is-active{% endif %}" data-slide-index="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- elsif section.settings.style == 'neon' -%}
    {%- if section.settings.hero_image != blank -%}
      <img
        class="hero__bg-image"
        src="{{ section.settings.hero_image | image_url: width: 1920 }}"
        alt="{{ section.settings.hero_image.alt | default: 'Carrito de compras tecnológico' | escape }}"
        width="1920"
        height="{{ 1920 | divided_by: section.settings.hero_image.aspect_ratio }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      {%- assign neon_slides = "hero-cart-neon.png|Carrito de compras tecnológico,hero-pets-banner.png|Todo lo que tu mascota necesita,hero-hogar-banner.png|Todo lo que tu hogar necesita" | split: "," -%}
      <div class="hero__carousel" data-hero-carousel>
        {%- for slide in neon_slides -%}
          {%- assign slide_parts = slide | split: "|" -%}
          <div class="hero__slide {% if forloop.first %}is-active{% endif %}">
            <img
              src="{{ slide_parts[0] | asset_url }}"
              alt="{{ slide_parts[1] }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              {% if forloop.first %}fetchpriority="high"{% endif %}
            >
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
    <canvas class="hero__particles" data-hero-particles aria-hidden="true"></canvas>
    <div class="hero__overlay hero__overlay--neon"></div>
    {%- if neon_slides.size > 1 -%}
      <button class="hero__carousel-arrow hero__carousel-arrow--prev" data-carousel-prev aria-label="Slide anterior">
        {% render 'icon', icon: 'arrow-left', size: 20 %}
      </button>
      <button class="hero__carousel-arrow hero__carousel-arrow--next" data-carousel-next aria-label="Siguiente slide">
        {% render 'icon', icon: 'arrow-right', size: 20 %}
      </button>
      <div class="hero__carousel-dots">
        {%- for slide in neon_slides -%}
          <button class="hero__carousel-dot {% if forloop.first %}is-active{% endif %}" data-slide-index="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- elsif section.settings.background_image -%}
    <img
      class="hero__bg-image"
      src="{{ section.settings.background_image | image_url: width: 1920 }}"
      alt=""
      loading="eager"
      fetchpriority="high"
    >
    <div class="hero__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  {%- else -%}
    <div class="hero__bg-pattern">
      <div class="hero__blob hero__blob--1"></div>
      <div class="hero__blob hero__blob--2"></div>
      <div class="hero__blob hero__blob--3"></div>
    </div>
  {%- endif -%}

  <div class="hero__content container-narrow">
    <div class="hero__text">
      {%- if section.settings.subtitle != blank -%}
        <span class="hero__tag">
          {% render 'icon', icon: 'star', size: 14 %}
          {{ section.settings.subtitle }}
        </span>
      {%- endif -%}

      <h1 class="hero__heading">
        {%- assign heading = section.settings.heading -%}
        {%- assign accent = section.settings.heading_accent -%}
        {%- if accent != blank and heading contains accent -%}
          {{ heading | replace: accent, '<span class="hero__accent">' | append: accent | append: '</span>' }}
        {%- else -%}
          {{ heading }}
        {%- endif -%}
      </h1>

      {%- if section.settings.description != blank -%}
        <p class="hero__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="hero__ctas">
        {%- if section.settings.cta1_text != blank -%}
          <a href="{{ section.settings.cta1_url | default: '/collections/all' }}" class="btn btn-accent btn-lg hero__cta-primary">
            {{ section.settings.cta1_text }}
            {% render 'icon', icon: 'arrow-right', size: 18 %}
          </a>
        {%- endif -%}
        {%- if section.settings.cta2_text != blank -%}
          <a href="{{ section.settings.cta2_url | default: '/collections/all' }}" class="btn btn-outline-light btn-lg">
            {{ section.settings.cta2_text }}
          </a>
        {%- endif -%}
      </div>

      <div class="hero__social-proof">
        <div class="hero__avatars">
          <span class="hero__avatar-dot" style="background:#C9A84C;">V</span>
          <span class="hero__avatar-dot" style="background:#2D5A3E;">M</span>
          <span class="hero__avatar-dot" style="background:#1B4332;">C</span>
          <span class="hero__avatar-dot" style="background:#D4B96A;">A</span>
        </div>
        <div class="hero__social-text">
          <div class="hero__stars">
            {%- for i in (1..5) -%}{% render 'icon', icon: 'star', size: 14 %}{%- endfor -%}
          </div>
          <span>+2,500 clientes satisfechos en Colombia</span>
        </div>
      </div>
    </div>

    <div class="hero__visual">
      {%- if section.settings.style == 'neon' -%}
        {%- comment -%} Imagen de fondo del hero neón; esta columna queda vacía a propósito (ver .hero--neon .hero__visual en theme.css) {%- endcomment -%}
      {%- elsif section.settings.hero_product != blank -%}
        <div class="hero__product-card">
          <a href="{{ section.settings.hero_product.url }}">
            <img
              src="{{ section.settings.hero_product.featured_image | image_url: width: 500 }}"
              alt="{{ section.settings.hero_product.title }}"
              width="500"
              height="500"
              loading="eager"
            >
          </a>
          <div class="hero__product-info">
            <span class="hero__product-name">{{ section.settings.hero_product.title }}</span>
            <span class="hero__product-price">{{ section.settings.hero_product.price | money_without_trailing_zeros }}</span>
          </div>
        </div>
      {%- else -%}
        <div class="hero__floating-cards">
          <div class="hero__float-card hero__float-card--1">
            {% render 'icon', icon: 'shield', size: 32 %}
            <span>INVIMA<br>Certificado</span>
          </div>
          <div class="hero__float-card hero__float-card--2">
            {% render 'icon', icon: 'truck', size: 32 %}
            <span>Envio<br>Gratis</span>
          </div>
          <div class="hero__float-card hero__float-card--3">
            {% render 'icon', icon: 'heart', size: 32 %}
            <span>100%<br>Natural</span>
          </div>
          <div class="hero__circle-badge">
            <span class="hero__circle-number">+2.5K</span>
            <span class="hero__circle-label">Clientes</span>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
(function() {
  var carousel = document.querySelector('[data-hero-carousel]');
  if (!carousel) return;

  var heroSection = carousel.parentElement;
  var slides = carousel.querySelectorAll('.hero__slide');
  var dots = heroSection.querySelectorAll('.hero__carousel-dot');
  if (slides.length <= 1) return;

  var heroContent = heroSection.querySelector('.hero__content');
  var heroOverlay = heroSection.querySelector('.hero__overlay');
  var current = 0;
  var interval = {{ section.settings.slide_interval | default: 5 }} * 1000;
  var timer;

  function goTo(index) {
    slides[current].classList.remove('is-active');
    if (dots[current]) dots[current].classList.remove('is-active');
    current = index;
    slides[current].classList.add('is-active');
    if (dots[current]) dots[current].classList.add('is-active');
    if (heroContent) heroContent.classList.toggle('is-hidden', current !== 0);
    if (heroOverlay) heroOverlay.classList.toggle('is-hidden', current !== 0);
  }

  function next() {
    goTo((current + 1) % slides.length);
  }

  function prev() {
    goTo((current - 1 + slides.length) % slides.length);
  }

  function startAutoplay() {
    timer = setInterval(next, interval);
  }

  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      clearInterval(timer);
      goTo(parseInt(dot.getAttribute('data-slide-index')));
      startAutoplay();
    });
  });

  var prevBtn = heroSection.querySelector('[data-carousel-prev]');
  var nextBtn = heroSection.querySelector('[data-carousel-next]');
  if (prevBtn) {
    prevBtn.addEventListener('click', function() {
      clearInterval(timer);
      prev();
      startAutoplay();
    });
  }
  if (nextBtn) {
    nextBtn.addEventListener('click', function() {
      clearInterval(timer);
      next();
      startAutoplay();
    });
  }

  startAutoplay();
})();
</script>

{% schema %}
{
  "name": "Banner Principal",
  "settings": [
    {
      "type": "select",
      "id": "style",
      "label": "Estilo del banner",
      "options": [
        { "value": "classic", "label": "Clásico (verde/dorado)" },
        { "value": "neon", "label": "Neón (portada nueva)" }
      ],
      "default": "classic"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Imagen de fondo (estilo Neón)",
      "info": "Se usa solo con el estilo Neón, como fondo completo del banner. Si no se sube ninguna, se usa la imagen por defecto del tema (assets/hero-cart-neon.png)"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Imagen de fondo unica (opcional)",
      "info": "Se usa solo si no hay slides configurados"
    },
    {
      "type": "product",
      "id": "hero_product",
      "label": "Producto destacado (opcional)"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Suplementos Premium"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Tu salud merece lo mejor"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Palabra destacada (dorado)",
      "default": "lo mejor"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripcion",
      "default": "Descubre nuestra linea de suplementos de grado farmaceutico, formulados con los mas altos estandares de calidad para tu bienestar diario."
    },
    {
      "type": "url",
      "id": "cta1_url",
      "label": "URL boton primario"
    },
    {
      "type": "text",
      "id": "cta1_text",
      "label": "Texto boton primario",
      "default": "Ver suplementos"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "URL boton secundario"
    },
    {
      "type": "text",
      "id": "cta2_text",
      "label": "Texto boton secundario",
      "default": "Comprar ahora"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacidad overlay (%)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60
    },
    {
      "type": "range",
      "id": "slide_interval",
      "label": "Segundos entre slides",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide de imagen",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen del slide"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Texto alternativo",
          "default": "Banner VitalPlus"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Principal"
    }
  ]
}
{% endschema %}
