{%- comment -%}
  VitalPlus - FAQ Accordion Section
  Features: breadcrumbs, grouped questions, contact CTA.
{%- endcomment -%}

<section class="section-padding">
  <div class="container-narrow" style="max-width: 48rem;">
    {% render 'breadcrumbs' %}

    <h1 class="font-display text-3xl font-bold text-center mb-2">{{ section.settings.heading }}</h1>
    <p class="text-muted text-center mb-12">{{ section.settings.subheading }}</p>

    <div class="space-y-2">
      {%- for block in section.blocks -%}
        {%- if block.type == 'heading' -%}
          <h2 class="faq-category-heading" {{ block.shopify_attributes }}>
            {{ block.settings.title }}
          </h2>
        {%- elsif block.type == 'question' -%}
          <details class="accordion-item" {{ block.shopify_attributes }}>
            <summary>
              {{ block.settings.question }}
              <span class="chevron">{% render 'icon', icon: 'chevron-down', size: 20 %}</span>
            </summary>
            <div class="accordion-item__content prose">
              {{ block.settings.answer }}
            </div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Contact CTA {%- endcomment -%}
    {%- if section.settings.show_contact_cta -%}
      <div class="faq-cta mt-12">
        <div class="faq-cta__icon">
          {% render 'icon', icon: 'message-circle', size: 24 %}
        </div>
        <h3 class="font-display font-semibold text-lg mb-1">{{ 'faq.cta_heading' | t }}</h3>
        <p class="text-sm text-muted mb-4">{{ 'faq.cta_text' | t }}</p>
        <a href="{{ section.settings.contact_url | default: '/pages/contacto' }}" class="btn btn-primary">
          {{ 'faq.cta_button' | t }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Preguntas Frecuentes",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Preguntas Frecuentes"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Encuentra respuestas a las dudas más comunes."
    },
    {
      "type": "checkbox",
      "id": "show_contact_cta",
      "label": "Mostrar CTA de contacto",
      "default": true
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Enlace de contacto"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Categoría",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título de categoría",
          "default": "General"
        }
      ]
    },
    {
      "type": "question",
      "name": "Pregunta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "¿Pregunta frecuente?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Respuesta",
          "default": "<p>Respuesta a la pregunta frecuente.</p>"
        }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    {
      "name": "Preguntas Frecuentes",
      "blocks": [
        { "type": "heading", "settings": { "title": "Productos" } },
        { "type": "question", "settings": { "question": "¿Sus productos requieren receta médica?", "answer": "<p>No, nuestros productos son suplementos alimenticios que no requieren receta médica. Sin embargo, recomendamos consultar con un profesional de la salud antes de iniciar cualquier suplementación.</p>" } },
        { "type": "question", "settings": { "question": "¿Sus productos tienen registro INVIMA?", "answer": "<p>Sí, todos nuestros productos cumplen con la normativa colombiana y cuentan con los registros sanitarios correspondientes.</p>" } },
        { "type": "question", "settings": { "question": "¿Puedo tomar varios suplementos al mismo tiempo?", "answer": "<p>En general sí, pero recomendamos consultar con un profesional de la salud para asegurar que no haya interacciones entre los suplementos.</p>" } },
        { "type": "heading", "settings": { "title": "Envíos y pagos" } },
        { "type": "question", "settings": { "question": "¿Cuánto tarda el envío?", "answer": "<p>Los envíos dentro de Bogotá tardan 1-2 días hábiles. Para el resto de Colombia, el tiempo estimado es de 3-5 días hábiles.</p>" } },
        { "type": "question", "settings": { "question": "¿Cómo puedo pagar?", "answer": "<p>Aceptamos tarjetas de crédito y débito, PSE, Nequi, Daviplata y pago contra entrega en ciudades principales.</p>" } },
        { "type": "question", "settings": { "question": "¿Hacen envíos internacionales?", "answer": "<p>Actualmente solo realizamos envíos dentro de Colombia. Estamos trabajando para expandir nuestro servicio a otros países.</p>" } },
        { "type": "heading", "settings": { "title": "Devoluciones y seguridad" } },
        { "type": "question", "settings": { "question": "¿Cuál es la política de devoluciones?", "answer": "<p>Aceptamos devoluciones dentro de los 30 días posteriores a la compra, siempre que el producto esté sin abrir y en su empaque original.</p>" } },
        { "type": "question", "settings": { "question": "¿Son seguros para personas con condiciones médicas?", "answer": "<p>Si tiene alguna condición médica preexistente, está embarazada o en período de lactancia, consulte con su médico antes de tomar cualquier suplemento.</p>" } }
      ]
    }
  ]
}
{% endschema %}
