<div class="customer-page">
  <div class="customer-page__icon">
    {% render 'icon', icon: 'users', size: 32 %}
  </div>
  <h1>{{ 'customer.register_title' | t }}</h1>
  <p class="customer-page__subtitle">{{ 'customer.register_subtitle' | t }}</p>

  {% form 'create_customer' %}
    {%- if form.errors -%}
      <div class="alert alert--warning mb-4">{{ form.errors | default_errors }}</div>
    {%- endif -%}

    <div class="grid grid-cols-2 gap-4">
      <div class="form-group">
        <label for="first-name">{{ 'customer.first_name' | t }}</label>
        <input type="text" id="first-name" name="customer[first_name]" class="input" required autocomplete="given-name">
      </div>

      <div class="form-group">
        <label for="last-name">{{ 'customer.last_name' | t }}</label>
        <input type="text" id="last-name" name="customer[last_name]" class="input" required autocomplete="family-name">
      </div>
    </div>

    <div class="form-group">
      <label for="email">{{ 'customer.email' | t }}</label>
      <input type="email" id="email" name="customer[email]" class="input" required autocomplete="email" placeholder="{{ 'customer.email_placeholder' | t }}">
    </div>

    <div class="form-group">
      <label for="password">{{ 'customer.password' | t }}</label>
      <div class="input-password-wrap">
        <input type="password" id="password" name="customer[password]" class="input" required autocomplete="new-password">
        <button type="button" class="input-password-toggle" data-toggle-password="password" aria-label="{{ 'customer.show_password' | t }}">
          {% render 'icon', icon: 'eye', size: 18 %}
        </button>
      </div>
    </div>

    <button type="submit" class="btn btn-primary btn-lg w-full mb-4">
      {{ 'customer.register' | t }}
    </button>

    <p class="text-center text-sm text-muted">
      {{ 'customer.have_account' | t }}
      <a href="/account/login" class="text-primary font-medium">{{ 'customer.login' | t }}</a>
    </p>
  {% endform %}
</div>
