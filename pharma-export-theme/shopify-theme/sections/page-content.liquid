{%- comment -%}
  VitalPlus - Generic Page Content Section
{%- endcomment -%}

<section class="section-padding">
  <div class="container-narrow" style="max-width: 48rem;">
    {% render 'breadcrumbs' %}
    <h1 class="font-display text-3xl font-bold mb-8">{{ page.title }}</h1>
    <div class="prose">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contenido de Página",
  "settings": []
}
{% endschema %}
