{%- comment -%}
  Renders star rating display.
  Usage: {% render 'star-rating', rating: 4.5, count: 128 %}
  Or from metafields: {% render 'star-rating', rating: product.metafields.custom.rating.value, count: product.metafields.custom.review_count.value %}
{%- endcomment -%}

{%- assign rating_value = rating | default: 0 | round -%}
{%- assign review_count = count | default: 0 -%}

<div class="star-rating">
  {%- for i in (1..5) -%}
    {%- if i <= rating_value -%}
      <span class="star star--filled">★</span>
    {%- else -%}
      <span class="star">★</span>
    {%- endif -%}
  {%- endfor -%}
  {%- if review_count > 0 -%}
    <span class="star-rating__count">({{ review_count }})</span>
  {%- endif -%}
</div>
