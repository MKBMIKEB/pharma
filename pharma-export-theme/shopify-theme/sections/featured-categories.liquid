<section class="section-padding">
  <div class="container-narrow">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="section-subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        <a href="{{ col.url }}" class="category-card" {{ block.shopify_attributes }}>
          <div class="category-card__icon">
            {% render 'icon', icon: block.settings.icon %}
          </div>
          <h3>{{ col.title | default: block.settings.title }}</h3>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Categorías Destacadas",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Nuestras Categorías"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Encuentra el suplemento ideal para ti"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Colección"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título (si no hay colección)",
          "default": "Categoría"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icono",
          "options": [
            { "value": "shield", "label": "Escudo (Salud)" },
            { "value": "zap", "label": "Rayo (Energía)" },
            { "value": "pill", "label": "Cápsula (Vitaminas)" },
            { "value": "moon", "label": "Luna (Sueño)" },
            { "value": "heart", "label": "Corazón (Inmunidad)" },
            { "value": "leaf", "label": "Hoja (Natural)" },
            { "value": "shield-check", "label": "Escudo check" },
            { "value": "award", "label": "Medalla" }
          ],
          "default": "pill"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Categorías Destacadas",
      "blocks": [
        { "type": "category", "settings": { "title": "Salud Masculina", "icon": "shield" } },
        { "type": "category", "settings": { "title": "Energía", "icon": "zap" } },
        { "type": "category", "settings": { "title": "Vitaminas", "icon": "pill" } },
        { "type": "category", "settings": { "title": "Sueño", "icon": "moon" } },
        { "type": "category", "settings": { "title": "Inmunidad", "icon": "heart" } }
      ]
    }
  ]
}
{% endschema %}
