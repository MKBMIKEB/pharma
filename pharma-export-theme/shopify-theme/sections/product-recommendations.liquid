<section class="section-padding" style="padding-top: 0;">
  <div class="container-narrow">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>

    <div
      class="grid grid-cols-2 md:grid-cols-4 gap-4 gap-6"
      data-product-recommendations
      data-url="{{ routes.product_recommendations_url }}?product_id={{ product.id }}&limit={{ section.settings.product_count }}&section_id={{ section.id }}"
    >
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        {%- for product in recommendations.products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Productos Relacionados",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Productos relacionados"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Número de productos",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Productos Relacionados"
    }
  ]
}
{% endschema %}
