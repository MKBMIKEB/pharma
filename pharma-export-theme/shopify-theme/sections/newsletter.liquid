<section class="newsletter section-padding">
  <div class="container-narrow" style="max-width: 40rem;">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="section-subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {% form 'customer', id: 'newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {%- if form.posted_successfully? -%}
        <p class="text-primary font-semibold text-center mb-4">{{ 'newsletter.success' | t }}</p>
      {%- endif -%}

      {%- if form.errors -%}
        <p class="text-destructive text-sm text-center mb-4">{{ form.errors | default_errors }}</p>
      {%- endif -%}

      <div class="newsletter__form">
        <input
          type="email"
          name="contact[email]"
          class="input"
          placeholder="{{ 'newsletter.placeholder' | t }}"
          required
          autocomplete="email"
        >
        <button type="submit" class="btn btn-primary btn-lg">
          {{ 'newsletter.subscribe' | t }}
        </button>
      </div>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Recibe ofertas exclusivas"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Suscríbete y obtén un 10% de descuento en tu primera compra."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
